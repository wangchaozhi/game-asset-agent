# ============================================================
# GameAsset Forge 环境配置
# 复制为 .env 后按需填写。所有配置均可选：
# 不配置任何密钥时，系统使用内置 mock 生成器 + 规则模板，
# 可完整跑通全流程（适合本地开发与体验）。
# ============================================================

# ---- 服务 ----
PORT=8787
HOST=127.0.0.1
# 素材与任务数据的存放目录
# 相对路径基于服务端工作目录（经 npm 脚本启动时为 packages/server）；需要固定位置请用绝对路径
DATA_DIR=./data
# 同时执行的生成任务数
QUEUE_CONCURRENCY=1

# ---- LLM（智能体大脑，可选）----
# 用于「美术总监 / 提示词工程师 / 审查官」三个智能体。
# 未配置时智能体自动降级为内置规则模板（无审查环节）。
# LLM_PROVIDER=anthropic | openai | none   （默认按密钥自动检测）
ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8

# OpenAI 兼容端点（OpenAI / DeepSeek / Ollama / vLLM 等均可）
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- 图像生成 Provider ----
# OpenAI Images（gpt-image-1 / dall-e-3）复用上面的 OPENAI_API_KEY

# Stability AI（Stable Image Core / SD3.5 / Ultra）
STABILITY_API_KEY=

# 本地 Stable Diffusion WebUI（AUTOMATIC1111，需开启 --api）
# SD_WEBUI_URL=http://127.0.0.1:7860
